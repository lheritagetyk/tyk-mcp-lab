{
  "openapi": "3.0.3",
  "info": {
    "title": "Basic Open API",
    "version": "1.0.0",
    "description": "Sample lab API: requests are proxied through the Tyk gateway to a local httpbin upstream. Useful for verifying the gateway is routing traffic, and for exercising request/response logging, headers, and OTel tracing."
  },
  "servers": [
    {
      "url": "http://tyk-gateway.localhost:8080/basic-open-api/"
    }
  ],
  "tags": [
    {
      "name": "http",
      "description": "HTTP request/response endpoints"
    },
    {
      "name": "auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "status",
      "description": "HTTP status code endpoints"
    }
  ],
  "security": [],
  "paths": {
    "/get": {
      "get": {
        "tags": ["http"],
        "summary": "Returns GET data",
        "description": "Returns the GET request data, including URL parameters, headers, etc.",
        "operationId": "getRequest",
        "parameters": [],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResponse"
                }
              }
            }
          }
        }
      }
    },
    "/post": {
      "post": {
        "tags": ["http"],
        "summary": "Returns POST data",
        "description": "Returns the POST request data, including form data, JSON, headers, etc.",
        "operationId": "postRequest",
        "parameters": [],
        "requestBody": {
          "description": "Data to be sent in the POST request",
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object"
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpResponse"
                }
              }
            }
          }
        }
      }
    },
    "/status/{statusCode}": {
      "get": {
        "tags": ["status"],
        "summary": "Returns specified HTTP status code",
        "description": "Returns a response with the specified HTTP status code",
        "operationId": "getStatus",
        "parameters": [
          {
            "name": "statusCode",
            "in": "path",
            "description": "HTTP status code to return",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 100,
              "maximum": 599
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK response"
          },
          "4XX": {
            "description": "Client error response"
          },
          "5XX": {
            "description": "Server error response"
          },
          "default": {
            "description": "Status code returned matches the requested code"
          }
        }
      }
    },
    "/headers": {
      "get": {
        "tags": ["http"],
        "summary": "Returns headers",
        "description": "Returns the request headers as the response body",
        "operationId": "getHeaders",
        "parameters": [],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeadersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/basic-auth/{user}/{passwd}": {
      "get": {
        "tags": ["auth"],
        "summary": "Basic auth protected endpoint",
        "description": "Challenges HTTP Basic Auth and returns authentication status",
        "operationId": "getBasicAuth",
        "parameters": [
          {
            "name": "user",
            "in": "path",
            "description": "Username for basic auth",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "passwd",
            "in": "path",
            "description": "Password for basic auth",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Basic auth credentials",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSuccess"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {},
    "schemas": {
      "HttpResponse": {
        "type": "object",
        "properties": {
          "args": {
            "type": "object",
            "description": "URL arguments"
          },
          "headers": {
            "type": "object",
            "description": "Request headers"
          },
          "origin": {
            "type": "string",
            "description": "Origin IP address"
          },
          "url": {
            "type": "string",
            "description": "Request URL"
          }
        }
      },
      "HeadersResponse": {
        "type": "object",
        "properties": {
          "headers": {
            "type": "object",
            "description": "Request headers"
          }
        }
      },
      "AuthSuccess": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "type": "string"
          }
        }
      }
    }
  },
  "x-tyk-api-gateway": {
    "info": {
      "id": "8a1f4c6d3e0b4f12a7e8d9c4b5a63721",
      "orgId": "5e9d9544a1dcd60001d0ed20",
      "name": "Basic Open API",
      "state": {
        "active": true,
        "internal": false
      }
    },
    "middleware": {
      "global": {
        "contextVariables": {
          "enabled": true
        },
        "trafficLogs": {
          "enabled": true
        }
      }
    },
    "server": {
      "detailedTracing": {
        "enabled": true
      },
      "listenPath": {
        "strip": true,
        "value": "/basic-open-api/"
      }
    },
    "upstream": {
      "proxy": {
        "enabled": false,
        "url": ""
      },
      "url": "http://httpbin:8080/"
    }
  }
}
